# ROADSoS Environment Variables

# Server configuration (leave blank for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: ESP32 API key for auth (future use)
# ESP32_API_KEY=your-secret-key-here

# Optional: SMS gateway for real alerts
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# EMERGENCY_CONTACT_NUMBER=
